{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hippiescientist.app/schemas/herb-mechanism.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["slug", "mechanism", "claims", "_provenance", "_review"],
  "properties": {
    "slug": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "mechanism": { "type": "string", "minLength": 1, "maxLength": 700 },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "claim", "source_ids"],
        "properties": {
          "id": { "type": "string", "pattern": "^clm_[0-9A-HJKMNP-TV-Z]{26}$" },
          "claim": { "type": "string", "minLength": 1, "maxLength": 240 },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^src_[0-9A-HJKMNP-TV-Z]{26}$" }
          }
        }
      }
    },
    "_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "sources"],
      "properties": {
        "run_id": { "type": "string", "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
              "id": { "type": "string", "pattern": "^src_[0-9A-HJKMNP-TV-Z]{26}$" },
              "title": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    },
    "_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "notes": { "type": "string", "maxLength": 500 }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hippiescientist.app/schemas/patch.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["patch_id", "created_at", "producer", "operations"],
  "properties": {
    "patch_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "minLength": 1 },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task", "entity_type", "entity_id", "field", "op", "value"],
        "properties": {
          "task": {
            "type": "string",
            "enum": [
              "herb_mechanism",
              "compound_mechanism",
              "dosage",
              "interactions",
              "sources_suggestion",
              "link_integrity"
            ]
          },
          "entity_type": { "type": "string", "enum": ["herb", "compound"] },
          "entity_id": { "type": "string", "minLength": 1 },
          "field": { "type": "string", "minLength": 1 },
          "op": { "type": "string", "enum": ["set", "append", "remove"] },
          "value": {}
        },
        "allOf": [
          {
            "if": { "properties": { "task": { "const": "herb_mechanism" } }, "required": ["task"] },
            "then": {
              "properties": {
                "entity_type": { "const": "herb" },
                "field": { "enum": ["/mechanism", "/claims/-", "/_provenance", "/_review"] }
              }
            }
          },
          {
            "if": { "properties": { "task": { "const": "compound_mechanism" } }, "required": ["task"] },
            "then": {
              "properties": {
                "entity_type": { "const": "compound" },
                "field": { "enum": ["/mechanism", "/claims/-", "/_provenance", "/_review"] }
              }
            }
          },
          {
            "if": { "properties": { "task": { "const": "link_integrity" } }, "required": ["task"] },
            "then": {
              "properties": {
                "entity_type": { "enum": ["herb", "compound"] },
                "field": { "enum": ["/activeCompounds", "/herbs", "/foundIn", "/_review"] },
                "op": { "const": "set" }
              }
            }
          }
        ]
      }
    }
  }
}

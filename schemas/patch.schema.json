{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hippiescientist.app/schemas/patch.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["patch_id", "created_at", "producer", "operations"],
  "properties": {
    "patch_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "minLength": 1 },
    "lane": { "type": "string", "enum": ["A", "B", "C"] },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task", "entity_type", "entity_id", "field", "op", "value"],
        "properties": {
          "task": {
            "type": "string",
            "enum": [
              "herb_mechanism",
              "compound_mechanism",
              "dosage",
              "interactions",
              "sources_suggestion",
              "link_integrity"
            ]
          },
          "entity_type": { "type": "string", "enum": ["herb", "compound"] },
          "entity_id": { "type": "string", "minLength": 1 },
          "field": { "type": "string", "minLength": 1 },
          "op": { "type": "string", "enum": ["set", "append", "remove"] },
          "value": {}
        },
        "allOf": [
          {
            "if": { "properties": { "task": { "const": "herb_mechanism" } }, "required": ["task"] },
            "then": {
              "properties": {
                "entity_type": { "const": "herb" },
                "field": { "enum": ["/mechanism", "/claims/-", "/_provenance", "/_review"] }
              }
            }
          },
          {
            "if": { "properties": { "task": { "const": "compound_mechanism" } }, "required": ["task"] },
            "then": {
              "properties": {
                "entity_type": { "const": "compound" },
                "field": { "enum": ["/mechanism", "/claims/-", "/_provenance", "/_review"] }
              }
            }
          },
          {
            "if": { "properties": { "task": { "const": "interactions" } }, "required": ["task"] },
            "then": {
              "properties": {
                "entity_type": { "const": "herb" },
                "field": { "enum": ["/interactions", "/interactionTags", "/_review", "/_provenance"] },
                "op": { "const": "set" }
              }
            }
          },
          {
            "if": { "properties": { "task": { "const": "link_integrity" } }, "required": ["task"] },
            "then": {
              "properties": {
                "entity_type": { "enum": ["herb", "compound"] },
                "field": { "enum": ["/activeCompounds", "/herbs", "/foundIn", "/_review"] },
                "op": { "const": "set" }
              }
            }
          },
          {
            "if": { "properties": { "task": { "const": "sources_suggestion" } }, "required": ["task"] },
            "then": {
              "properties": {
                "entity_type": { "enum": ["herb", "compound"] },
                "field": { "const": "/sources/-" },
                "op": { "const": "append" },
                "value": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["title", "suggested", "verified"],
                  "properties": {
                    "title": { "type": "string", "minLength": 1 },
                    "url": { "type": "string", "format": "uri", "pattern": "^https?://" },
                    "doi": { "type": "string", "pattern": "^10\\.\\d{4,9}\\/[\\w.()/:;<>-]+$" },
                    "journal": { "type": "string", "minLength": 1 },
                    "year": { "type": "integer", "minimum": 1800, "maximum": 2100 },
                    "suggested": { "type": "boolean", "const": true },
                    "verified": { "type": "boolean", "const": false },
                    "notes": { "type": "string", "minLength": 1 }
                  },
                  "anyOf": [
                    { "required": ["url"], "properties": { "url": { "type": "string" } } },
                    { "required": ["doi"], "properties": { "doi": { "type": "string" } } }
                  ]
                }
              }
            }
          }
        ]
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "operations": {
            "type": "array",
            "contains": {
              "type": "object",
              "properties": { "task": { "const": "sources_suggestion" } },
              "required": ["task"]
            }
          }
        },
        "required": ["operations"]
      },
      "then": { "properties": { "lane": { "const": "C" } } }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hippiescientist.app/schemas/interactions.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["severity", "mechanism", "tags"],
  "properties": {
    "severity": { "type": "string", "enum": ["low", "moderate", "high", "unknown"] },
    "mechanism": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  }
}

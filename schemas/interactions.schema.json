{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hippiescientist.app/schemas/interactions.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "interactionTags",
    "interactions"
  ],
  "properties": {
    "interactionTags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "https://hippiescientist.app/schemas/interaction-tags.vocab.json"
      }
    },
    "interactions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "substance",
          "severity",
          "evidence",
          "mechanism",
          "tags"
        ],
        "properties": {
          "substance": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "mild",
              "moderate",
              "severe",
              "contraindicated"
            ]
          },
          "evidence": {
            "type": "string",
            "enum": [
              "theoretical",
              "anecdotal",
              "case_report",
              "clinical"
            ]
          },
          "mechanism": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "https://hippiescientist.app/schemas/interaction-tags.vocab.json"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}

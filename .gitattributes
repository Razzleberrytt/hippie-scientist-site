# Normalize all text files to LF on checkout
* text=auto eol=lf

# Binary — never convert
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.pdf  binary
*.zip  binary
*.xlsx binary

# Explicit LF for source types
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.mdx  text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.sh   text eol=lf

name: Daily Blog Post

# Schedule disabled — posts are now written manually.
# Re-enable the cron line only when a reviewed content pipeline is ready.
on:
  workflow_dispatch: {}

permissions:
  contents: write

jobs:
  generate:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          persist-credentials: false
          ssh-key: ${{ secrets.ACTIONS_DEPLOY_KEY }}

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: npm

      - name: Install
        run: npm ci

      - name: Generate today's post
        run: node scripts/generate-daily-post.mjs

      - name: Enrich herb and compound data
        run: npm run data:enrich

      - name: Sync blog outputs
        run: npm run sync:blog

      - name: Commit and push if changed
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add content/blog public/blog public/blogdata public/data/herbs.json public/data/compounds.json public/sitemap.xml
          git diff --cached --quiet && echo "No changes" || (git commit -m "chore(blog): daily post $(date -u +'%Y-%m-%d')" && git push)


      - name: Deployment handoff
        run: |
          echo "Cloudflare Pages picks up main-branch commits automatically via Git integration."

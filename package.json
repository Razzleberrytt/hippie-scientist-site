{
  "name": "hippie-scientist-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <=22"
  },
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "data:build": "node scripts/data/build-runtime-from-workbook.mjs --out public/data",
    "data:validate": "node scripts/data/validate-data-next.mjs --data-dir public/data",
    "data:audit": "node scripts/check-generated-output.mjs",
    "guard:source-of-truth": "node scripts/data/verify-workbook-only-path.mjs",
    "lint": "eslint . --max-warnings=0",
    "build": "npm run data:build && npm run data:validate && npm run data:audit && npm run guard:source-of-truth && next build && npm run verify:build",
    "verify:build": "node scripts/verify-redirects.mjs && node scripts/ci/validate-deploy-readiness.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@headlessui/react": "^2.2.10",
    "@tsparticles/engine": "^3.8.1",
    "@tsparticles/react": "^3.0.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "clsx": "^2.1.1",
    "csv-parse": "^5.5.6",
    "dompurify": "^3.3.3",
    "framer-motion": "^10.18.0",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.298.0",
    "marked": "^12.0.2",
    "next": "^15.3.2",
    "papaparse": "^5.5.3",
    "react": "^18.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "resend": "^6.9.4",
    "slugify": "^1.6.6",
    "sonner": "^2.0.7",
    "three": "^0.180.0",
    "tsparticles": "^3.8.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "autoprefixer": "^10.4.19",
    "chokidar": "^4.0.3",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.34.4",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.7",
    "postcss": "^8.4.31",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "stylelint": "^16.9.0",
    "stylelint-config-standard": "^36.0.0",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --max-warnings=0",
    "*.{js,mjs,cjs}": "eslint --max-warnings=0"
  }
}
